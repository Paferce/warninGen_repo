# Variables de Entorno para Docker Compose
# Copiar este archivo a .env y configurar con valores reales

# Base de Datos
DB_HOST=database
DB_USER=alertas_user
DB_PASSWORD=cambiar_en_produccion
DB_NAME=sistema_alertas

# Twilio (SMS y WhatsApp)
TWILIO_ACCOUNT_SID=tu_account_sid
TWILIO_AUTH_TOKEN=tu_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890
WHATSAPP_CONTENT_SID=tu_content_sid

# Email (SMTP)
EMAIL_USER=tu_email@ejemplo.com
EMAIL_PASS=tu_contraseña
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@ejemplo.com
SMTP_PASSWORD=tu_contraseña
SMTP_FROM_EMAIL=tu_email@ejemplo.com
SMTP_FROM_NAME=Sistema de Alertas

# Frontend
FRONTEND_URL=http://localhost
