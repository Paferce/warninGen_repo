# Configuración del Servidor
NODE_ENV=production
PORT=3001

# Configuración de Base de Datos MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=sistema_alertas

# Configuración de Twilio (SMS y WhatsApp)
TWILIO_ACCOUNT_SID=tu_account_sid_aqui
TWILIO_AUTH_TOKEN=tu_auth_token_aqui
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890
WHATSAPP_CONTENT_SID=tu_content_sid_aqui

# Configuración de Email (SMTP)
EMAIL_USER=tu_email@ejemplo.com
EMAIL_PASS=tu_contraseña_aqui
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@ejemplo.com
SMTP_PASSWORD=tu_contraseña_aqui
SMTP_FROM_EMAIL=tu_email@ejemplo.com
SMTP_FROM_NAME=Sistema de Alertas

# URL del Frontend (para CORS)
FRONTEND_URL=http://localhost:3000
